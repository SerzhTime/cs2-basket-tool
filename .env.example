# Local-only configuration. Copy this file to .env and fill in values as needed.

# Optional shared Postgres database for mixed local/cloud mode.
# If unset, the app uses local SQLite at data/price_history.sqlite.
DATABASE_URL=
# Optional override: set to sqlite for fastest local-only mode even when DATABASE_URL is set.
# Leave empty or set to postgres to use the shared Neon/Postgres database.
DATABASE_BACKEND=

# Optional UI password. Mostly useful for Streamlit Cloud.
APP_PASSWORD=

# C5Game batch price API.
C5GAME_API_URL=https://openapi.c5game.com/merchant/product/price/batch
C5GAME_APP_KEY=
C5GAME_APP_ID=730
C5GAME_TIMEOUT_SECONDS=20

# C5Game returns CNY prices. During each price update, the app fetches the
# current USD -> CNY rate here and stores C5Game prices as converted USD.
EXCHANGERATE_USD_LATEST_URL=
EXCHANGERATE_TIMEOUT_SECONDS=15

# CSFloat listing API. Prices are returned in cents and normalized to USD.
CSFLOAT_LISTINGS_URL=https://csfloat.com/api/v1/listings
CSFLOAT_API_KEY=
CSFLOAT_LIMIT=5
CSFLOAT_TIMEOUT_SECONDS=20

# Waxpeer bulk price API. `min` is treated as cents and normalized to USD.
WAXPEER_PRICES_URL=https://api.waxpeer.com/v1/prices
WAXPEER_API_KEY=
WAXPEER_GAME=csgo
WAXPEER_CURRENCY=USD
WAXPEER_PRICE_DIVISOR=1000
WAXPEER_TIMEOUT_SECONDS=30

# DMarket v2 lowest-offer endpoint. Requires Ed25519 request signing.
DMARKET_BASE_URL=https://api.dmarket.com
DMARKET_OFFERS_PATH=/marketplace-api/v2/offers
DMARKET_GAME_ID=a8db
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=
DMARKET_TIMEOUT_SECONDS=20
DMARKET_PAGE_LIMIT=100
DMARKET_MAX_PAGES_PER_ITEM=3
DMARKET_USER_AGENT=Mozilla/5.0 (compatible; local-cs2-basket-tool/1.0)

# Market.CSGO bulk price API. USD endpoint returns exact market_hash_name, price, and volume.
MARKETCSGO_PRICES_URL=https://market.csgo.com/api/v2/prices/USD.json
MARKETCSGO_API_KEY=
MARKETCSGO_CURRENCY=USD
MARKETCSGO_TIMEOUT_SECONDS=40

# Skinport marketplace API. Requires Brotli support.
SKINPORT_ITEMS_URL=https://api.skinport.com/v1/items
SKINPORT_CLIENT_ID=
SKINPORT_CLIENT_SECRET=
SKINPORT_APP_ID=730
SKINPORT_CURRENCY=USD
SKINPORT_TRADABLE=1
SKINPORT_TIMEOUT_SECONDS=30
SKINPORT_USER_AGENT=local-cs2-basket-tool/1.0

# Skindeck secure market API. Uses exact market_hash_name matches only.
SKINDECK_MARKET_URL=https://api.skindeck.com/secure/market
SKINDECK_API_KEY=
SKINDECK_API_SECRET=
SKINDECK_GAME_ID=730
SKINDECK_PER_PAGE=10
SKINDECK_TIMEOUT_SECONDS=30
SKINDECK_DELAY_SECONDS=0.05
SKINDECK_USER_AGENT=local-cs2-basket-tool/1.0

# OpenSkin public batch API. Used for Buff163, YouPin, and Steam asks.
OPENSKIN_BATCH_URL=https://api.openskin.dev/v1/prices/batch
OPENSKIN_TIMEOUT_SECONDS=40
OPENSKIN_USER_AGENT=local-cs2-basket-tool/1.0

# Experimental ShadowPay merchant price API.
# Not active by default; ShadowPay currently uses the CSGOSKINS-backed adapter.
# The Steam web access token from steamcommunity.com is not enough for this price endpoint.
SHADOWPAY_PRICES_URL=https://api.shadowpay.com/api/v2/merchant/items/prices
SHADOWPAY_API_TOKEN=
SHADOWPAY_PROJECT=csgo
SHADOWPAY_TIMEOUT_SECONDS=40

# CSGOSKINS item pages for marketplaces without APIs.
# Each page is fetched once per update and shared across all CSGOSKINS-backed marketplaces.
CSGOSKINS_TIMEOUT_SECONDS=30
CSGOSKINS_FETCH_MODE=reader
CSGOSKINS_READER_URL_TEMPLATE=https://r.jina.ai/http://{url}
CSGOSKINS_DELAY_SECONDS=4.0
CSGOSKINS_DELAY_JITTER_SECONDS=4.0
CSGOSKINS_RETRIES=0
CSGOSKINS_RETRY_BACKOFF_SECONDS=15
CSGOSKINS_USER_AGENT=Mozilla/5.0 (compatible; local-cs2-basket-tool/1.0)

# Lower-priority backup source for missing primary prices.
# SteamAnalyst is only checked for item/marketplace results that stayed missing
# after API/CSGOSKINS adapters finish.
STEAMANALYST_BACKUP_ENABLED=1
STEAMANALYST_TIMEOUT_SECONDS=30
STEAMANALYST_DELAY_SECONDS=0.75
STEAMANALYST_BACKUP_MIN_BASELINE_RATIO=0.1
STEAMANALYST_BACKUP_MAX_BASELINE_RATIO=4.0
STEAMANALYST_USER_AGENT=Mozilla/5.0 (compatible; local-cs2-basket-tool/1.0)

# PriceEmpire backup source for listings that are not exposed by API/CSGOSKINS.
PRICEEMPIRE_TIMEOUT_SECONDS=30
PRICEEMPIRE_DELAY_SECONDS=0.75
PRICEEMPIRE_USER_AGENT=Mozilla/5.0 (compatible; local-cs2-basket-tool/1.0)

# Manual repair direct marketplace pages. Used only by "Repair Missing Marketplace Prices"
# for non-API marketplaces before falling back to third-party price-compare pages.
DIRECT_MARKET_PAGE_TIMEOUT_SECONDS=25
DIRECT_MARKET_PAGE_DELAY_SECONDS=0.75
DIRECT_MARKET_PAGE_MAX_CHARS=900000
DIRECT_MARKET_MIN_BASELINE_RATIO=0.5
DIRECT_MARKET_MAX_BASELINE_RATIO=2.0
DIRECT_MARKET_PAGE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/126 Safari/537.36

# HaloSkins lowest-price list API.
HALOSKINS_LOWEST_PRICE_URL=
HALOSKINS_API_KEY=
HALOSKINS_CURRENCY=USD
HALOSKINS_TIMEOUT_SECONDS=30
HALOSKINS_USER_AGENT=Mozilla/5.0 (compatible; local-cs2-basket-tool/1.0)

# Currency normalization into USD for cross-marketplace comparison.
# Use only for adapters that still return non-USD source prices.
FX_CNY_TO_USD=

# Generic webpage adapter for a price-compare website when no API is available.
# Leave disabled in the UI until these values are filled.
# Use {item} for URL-encoded market_hash_name or {item_raw} for the exact raw name.
PRICE_COMPARE_WEB_MARKETPLACE_NAME=PriceCompare Web
PRICE_COMPARE_WEB_URL_TEMPLATE=
PRICE_COMPARE_WEB_PRICE_SELECTOR=
PRICE_COMPARE_WEB_PRICE_REGEX=
PRICE_COMPARE_WEB_STOCK_SELECTOR=
PRICE_COMPARE_WEB_CURRENCY=USD
PRICE_COMPARE_WEB_DELAY_SECONDS=0.5
PRICE_COMPARE_WEB_TIMEOUT_SECONDS=15
